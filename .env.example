# Optional OpenAI-compatible model endpoint for report analysis.
# If these are not set, AutoVT still runs tests and uses a rule-based summary.
AI_API_KEY=""
AI_BASE_URL=""
AI_MODEL="qwen2.5-vl-72b-instruct"

# Optional OpenAI-compatible vision endpoint for screenshot diagnosis.
# Leave empty to use built-in heuristic fallback. For Qwen VL, set these
# to your internal endpoint and model name.
VISION_ENABLED=true
VISION_API_KEY=""
VISION_BASE_URL=""
VISION_MODEL="qwen-vl-max"

APP_URL="MY_APP_URL"
